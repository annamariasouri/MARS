{
  "name": "MARS",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": ["README.md", "streamlit_app.py", "web/app.jsx"]
    },
    "vscode": {
      "extensions": ["ms-python.python", "ms-python.vscode-pylance"]
    }
  },
  "updateContentCommand": "pip3 install --user -r requirements.txt",
  "postAttachCommand": {
    "dashboard": "streamlit run streamlit_app.py --server.port 8765 --server.headless true"
  },
  "portsAttributes": {
    "8765": {
      "label": "MARS Dashboard",
      "onAutoForward": "openBrowser"
    }
  },
  "forwardPorts": [8765]
}
